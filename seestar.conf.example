# seestar.conf — local configuration for seestar-tools
# Copy this file to seestar.conf and edit the paths to match your setup.
# seestar.conf is gitignored so your personal paths stay off GitHub.

# Source path: Seestar EMMC when connected via USB
SEESTAR_EMMC="/Volumes/EMMC Images/MyWorks/"

# Destination path: your NAS Seestar archive folder
SEESTAR_NAS="/Volumes/personal_folder/Seestar/"

# Full path to AstroImages Inventory.md in your Obsidian vault
# Tilde (~) is expanded automatically.
SEESTAR_VAULT_INV="~/Library/Mobile Documents/iCloud~md~obsidian/Documents/Obsidian Vault/Astrophotography/AstroImages Inventory.md"
