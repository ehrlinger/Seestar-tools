# Personal config — copy seestar.conf.example → seestar.conf and fill in your paths
seestar.conf

# macOS
.DS_Store
._*
.AppleDouble
.LSOverride

# Python
__pycache__/
*.pyc
*.pyo
*.pyd
.Python

# NAS keepalive sentinel (created at runtime by batch_stack.py)
.seestar_keepalive

# Siril intermediate files (not source data)
*.seq
pp_*.fit
r_pp_*.fit

# NAS auto-mount real config (personal network details)
setup/nas-mount/nas-mount.conf
